BLOG_API_URL="https://jsonplaceholder.typicode.com/posts"

# YouTube Data API v3 — episodes are fetched from the channel uploads at build time
YOUTUBE_API_KEY="YOUR_YOUTUBE_DATA_API_V3_KEY"
YOUTUBE_CHANNEL_ID="UCxxxxxxxxxxxxxxxxxxxxxxxx"

# Spotify — optional. Adds a "Listen on Spotify" link to each matching episode.
# Get Client ID/Secret at https://developer.spotify.com/dashboard
# SPOTIFY_SHOW_ID is the id in the show URL: open.spotify.com/show/<SHOW_ID>
SPOTIFY_CLIENT_ID="YOUR_SPOTIFY_CLIENT_ID"
SPOTIFY_CLIENT_SECRET="YOUR_SPOTIFY_CLIENT_SECRET"
SPOTIFY_SHOW_ID="033BP1wbSxThsM7iHyfzP0"
