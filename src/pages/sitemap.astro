---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Heading } from 'accessible-astro-components'
import { getCollection } from 'astro:content'

const episodes = await getCollection('episodes')
const sortedEpisodes = episodes.sort((a, b) => (a.data.episodeNumber ?? 0) - (b.data.episodeNumber ?? 0))

const staticPages = [
  {
    title: 'Home',
    url: '/',
    description: 'Welcome to South Asian Women in Rare.',
  },
  {
    title: 'Episodes',
    url: '/episodes',
    description: 'Browse all podcast episodes featuring South Asian women sharing their rare disease experiences.',
  },
  {
    title: 'About Us',
    url: '/about',
    description: 'Learn about our mission, our hosts, and the story behind South Asian Women in Rare.',
  },
  {
    title: 'Contact',
    url: '/contact',
    description: 'Get in touch — share your story or connect with us.',
  },
  {
    title: 'Accessibility Statement',
    url: '/accessibility-statement',
    description: 'Our commitment to making this website accessible for everyone.',
  },
]
---

<DefaultLayout title="Sitemap" description="Complete sitemap for South Asian Women in Rare — all pages and episodes.">
  <PageHeader
    title="Sitemap"
    subtitle="An overview of all pages and episodes available on our website."
    bgType="gradient"
  />

  <section class="my-16">
    <div class="container space-y-12">
      <div>
        <Heading level="h2" class="mb-6">Pages</Heading>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            staticPages.map((page) => (
              <article>
                <Heading level="h3" size="h6" class="mb-2">
                  <a href={page.url}>{page.title}</a>
                </Heading>
                <p>{page.description}</p>
              </article>
            ))
          }
        </div>
      </div>

      {
        sortedEpisodes.length > 0 && (
          <div>
            <Heading level="h2" class="mb-6">Episodes</Heading>
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
              {sortedEpisodes.map((episode) => (
                <article>
                  <Heading level="h3" size="h6" class="mb-1">
                    <a href={`/episodes/${episode.id}`}>
                      {episode.data.episodeNumber ? `Ep. ${episode.data.episodeNumber}: ` : ''}
                      {episode.data.title}
                    </a>
                  </Heading>
                  {episode.data.guestName && (
                    <p>with {episode.data.guestName}</p>
                  )}
                </article>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>

<style>
  article {
    border: 1px solid var(--border-color-subtle);
    border-radius: var(--radius-large);
    background-color: var(--background-color);
    padding: 1rem;
  }
</style>
