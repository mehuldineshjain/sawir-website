---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Form, Input, Button, Textarea, Fieldset, Heading, Link, Radio } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Contact Us">
  <PageHeader
    title="Contact Us"
    subtitle="Have a question, a story to share, or want to collaborate? Get in touch with us!"
    bgType="gradient"
  />

  <section class="my-16">
    <div class="container">
      <Heading level="h2">Let's talk</Heading>
    </div>
  </section>

  <section class="container mb-24">
    <div class="grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-32">
      <div class="space-content">
        {/*
          Static form for Netlify build-time detection. The visible form below is rendered by the
          accessible-astro `Form` component, which strips the `name` attribute — so Netlify can't
          detect it. This hidden twin registers the "contact" form + its fields with Netlify.
        */}
        <form name="contact" data-netlify="true" hidden aria-hidden="true">
          <input type="text" name="fullname" />
          <input type="email" name="email" />
          <input type="tel" name="phone" />
          <textarea name="message"></textarea>
          <input type="radio" name="identity" value="Patient" />
        </form>

        <Form name="contact" class="contact-form" action="/thank-you" method="post" data-netlify="true">
          {/* Required by Netlify for AJAX submissions */}
          <input type="hidden" name="form-name" value="contact" />

          <Input
            name="fullname"
            label="Full name"
            required
            data-validation="We need your full name to address you correctly"
            autocomplete="given-name"
          />

          <Input name="email" label="Email address" type="email" required autocomplete="email" />

          <Input name="phone" label="Phone number (Optional)" type="tel" />

          <Textarea name="message" label="How can we help you? / Share your story idea" required />

          <Fieldset name="identity" legend="How do you associate with us?" required>
            <Radio name="identity" value="Patient" label="Patient living with a rare condition" />
            <Radio name="identity" value="Parent/Caregiver" label="Parent or Caregiver" />
            <Radio name="identity" value="Healthcare Worker" label="Healthcare worker / Researcher" />
            <Radio name="identity" value="Organisation" label="Patient organisation or Changemaker" />
            <Radio name="identity" value="Advocate" label="Advocate in the rare disease space" />
          </Fieldset>

          <Button htmlType="submit" type="primary">Send Message</Button>
        </Form>
      </div>

      <div class="space-content">
        <Heading level="h3">Get in Touch</Heading>
        <p class="text-lg">
          Do you identify as a South Asian woman associated with rare diseases? Would you like to be a guest on our
          podcast? Or perhaps you have some questions for our team?
        </p>
        <p>
          Feel free to fill out the form, and a member of our team will get back to you shortly. Every voice deserves to
          be heard.
        </p>

        <div class="gap-2xs mt-6 flex items-center">
          <Icon aria-hidden="true" name="lucide:mail" size={20} class="flex-shrink-0" />
          <p>
            <span class="font-bold">Email:</span>
            <Link href="mailto:southasianwomeninrare@gmail.com">southasianwomeninrare@gmail.com</Link>
          </p>
        </div>

        <hr class="my-6 border-neutral-300" />

        <Heading level="h4">Follow Our Journey</Heading>
        <ul class="mt-2 flex flex-wrap gap-4">
          <li>
            <Link href="https://facebook.com" isButton isExternal hideIcon animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:facebook" size={32} />
              <span class="sr-only">Go to our Facebook page, opens in a new tab</span>
            </Link>
          </li>
          <li>
            <Link href="https://instagram.com" isButton isExternal hideIcon animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:instagram" size={32} />
              <span class="sr-only">Go to our Instagram profile, opens in a new tab</span>
            </Link>
          </li>
          <li>
            <Link href="https://linkedin.com" isButton isExternal hideIcon animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:linkedin" size={32} />
              <span class="sr-only">Go to our LinkedIn page, opens in a new tab</span>
            </Link>
          </li>
          <li>
            <Link href="#" isButton isExternal hideIcon animateOnHover animationType="boop">
              <Icon aria-hidden="true" name="lucide:audio-waveform" size={32} />
              <span class="sr-only">Listen to our podcast, opens in a new tab</span>
            </Link>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <script>
    function setupContactForm() {
      const form = document.querySelector<HTMLFormElement>('form.contact-form')
      if (!form || form.dataset.netlifyInit === 'true') return
      form.dataset.netlifyInit = 'true'

      // Override the submit method called by the Form component after validation passes.
      // Posts to Netlify via fetch instead of a page redirect, then shows a toast.
      form.submit = async () => {
        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')
        if (submitBtn) submitBtn.disabled = true

        try {
          await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(new FormData(form) as any).toString(),
          })
          form.reset()
          showToast()
        } catch {
          alert('Sorry, something went wrong. Please email us at southasianwomeninrare@gmail.com.')
        } finally {
          if (submitBtn) submitBtn.disabled = false
        }
      }
    }

    function showToast() {
      // Remove any existing toast
      document.getElementById('contact-toast')?.remove()

      const toast = document.createElement('div')
      toast.id = 'contact-toast'
      toast.setAttribute('role', 'status')
      toast.setAttribute('aria-live', 'polite')
      toast.innerHTML = `
        <span class="toast-icon">✓</span>
        <div>
          <strong>Message sent!</strong>
          <p>Thanks for reaching out. We'll get back to you soon.</p>
        </div>
        <button class="toast-close" aria-label="Dismiss notification">✕</button>
      `
      document.body.appendChild(toast)

      // Trigger enter animation
      requestAnimationFrame(() => toast.classList.add('toast--visible'))

      const dismiss = () => {
        toast.classList.remove('toast--visible')
        toast.addEventListener('transitionend', () => toast.remove(), { once: true })
      }

      toast.querySelector('.toast-close')!.addEventListener('click', dismiss)

      // Auto-dismiss after 5 seconds
      setTimeout(dismiss, 5000)
    }

    document.addEventListener('astro:page-load', setupContactForm)
  </script>

  <style is:global>
    #contact-toast {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 9999;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      max-width: 22rem;
      padding: 1rem 1.25rem;
      border-radius: 0.75rem;
      background: var(--foreground-color, #1a1a1a);
      color: var(--background-color, #fff);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transform: translateY(1rem);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
      pointer-events: none;
    }

    #contact-toast.toast--visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    #contact-toast .toast-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 1.75rem;
      height: 1.75rem;
      border-radius: 50%;
      background: var(--color-primary, #e6a23c);
      color: #fff;
      font-size: 0.85rem;
      font-weight: bold;
    }

    #contact-toast strong {
      display: block;
      font-size: 1rem;
      margin-bottom: 0.2rem;
    }

    #contact-toast p {
      margin: 0;
      font-size: 0.875rem;
      opacity: 0.85;
    }

    #contact-toast .toast-close {
      flex-shrink: 0;
      margin-left: auto;
      padding: 0.1rem 0.3rem;
      background: transparent;
      border: none;
      color: inherit;
      opacity: 0.6;
      cursor: pointer;
      font-size: 0.85rem;
      line-height: 1;
    }

    #contact-toast .toast-close:hover {
      opacity: 1;
    }

    @media (max-width: 480px) {
      #contact-toast {
        right: 1rem;
        left: 1rem;
        max-width: none;
        bottom: 1rem;
      }
    }
  </style>
</DefaultLayout>
