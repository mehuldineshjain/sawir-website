---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import SocialShares from '@components/SocialShares.astro'
// import BreakoutImage from '@components/BreakoutImage.astro'
import { Badge, Heading } from 'accessible-astro-components'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { post: post.id },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(post.data.publishDate))

const author = {
  name: post.data.author,
  image: post.data.featuredImage ?? '/posts/post-image-1.png',
  bio: 'South Asian Women in Rare',
}
---

<DefaultLayout title={post.data.title} description={post.data.description} url={`/blog/${post.id}`}>
  <PageHeader
    title={post.data.title}
    subtitle={post.data.description}
    author={author}
    bgType="bordered"
    featuredImage={post.data.featuredImage}
  />

  <section class="my-12">
    <div class="narrow container">
      <!-- Meta -->
      <div class="mb-8 flex flex-wrap items-center gap-3">
        <span class="text-sm text-neutral-500">{formattedDate}</span>
        {post.data.tags.map((tag) => <Badge>{tag}</Badge>)}
      </div>

      <!-- Post content -->
      <div class="space-content prose max-w-none">
        <Content />
      </div>
    </div>
  </section>

  <section class="my-12">
    <div class="narrow space-content container">
      <Heading level="h2">Share this post</Heading>
      <p>Found this helpful? Share it with your community.</p>
      <SocialShares />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .narrow {
    margin-inline: auto;
    max-width: 65ch;
  }
</style>
