---
import { Link } from 'accessible-astro-components'
import themeConfig from '@theme-config'

interface Props {
  loading?: 'eager' | 'lazy'
}

const { loading = 'eager' }: Props = Astro.props
---

<Link href="/" class="flex items-center gap-2">
  <img src="/Logo-Light.svg" alt="" aria-hidden="true" width="47" height="37" loading={loading} class="logo-light" />
  <img src="/Logo-Dark.svg" alt="" aria-hidden="true" width="47" height="37" loading={loading} class="logo-dark" />
  <span class="text-sm font-bold sm:text-lg">{themeConfig.name}</span>
</Link>

<style>
  .logo-dark {
    display: none;
  }
  :global(.darkmode) .logo-dark {
    display: inline;
  }
  :global(.darkmode) .logo-light {
    display: none;
  }
</style>
