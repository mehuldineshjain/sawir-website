---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
// import { Accordion, AccordionItem, Heading, Link } from 'accessible-astro-components'
// import YouTubePlayer from '@components/YouTubePlayer.astro'

const episodes = await getCollection('episodes')
const latestEpisode = episodes.sort((a, b) => (b.data.episodeNumber ?? 0) - (a.data.episodeNumber ?? 0))[0]
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h2 class="text-center text-6xl md:text-left lg:text-8xl">
          <slot><span class="text-gradient">South Asian Women in Rare</span> Podcast </slot>
        </h2>
        <!-- <Image class="hidden lg:block" src={src} alt="" decoding="async" width={400} height={300} loading="eager" /> -->
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link href={`/episodes/${latestEpisode?.id}`} isButton type="primary" animateOnHover animationType="boop">
            <Icon aria-hidden="true" name="lucide:star" size="1.5rem" />
            Latest Episode
          </Link>
          <div class="listen-dropdown">
            <button
              class="button button--filled type-secondary button--md"
              id="listen-btn"
              aria-expanded="false"
              aria-controls="listen-menu"
            >
              <Icon aria-hidden="true" name="lucide:headphones" size="1.5rem" />
              Listen on...
            </button>
            <div id="listen-menu" class="listen-menu" role="menu" aria-labelledby="listen-btn" hidden>
              <a href="https://www.youtube.com/@SouthAsianWomeninRare" target="_blank" rel="noopener noreferrer" role="menuitem" class="listen-item">
                <Icon aria-hidden="true" name="youtube" size="1.25rem" />
                YouTube
              </a>
              <a href="https://open.spotify.com/show/033BP1wbSxThsM7iHyfzP0" target="_blank" rel="noopener noreferrer" role="menuitem" class="listen-item">
                <Icon aria-hidden="true" name="spotify" size="1.25rem" />
                Spotify
              </a>
              <a href="https://podcasts.apple.com/us/podcast/south-asian-women-in-rare/id1896945463" target="_blank" rel="noopener noreferrer" role="menuitem" class="listen-item">
                <Icon aria-hidden="true" name="apple-podcast" size="1.25rem" />
                Apple Podcasts
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-logo hidden lg:block">
        <Image src="/Logo-Light.svg" alt="" decoding="async" width={800} height={600} loading="eager" class="logo-light" />
        <Image src="/Logo-Dark.svg" alt="" decoding="async" width={800} height={600} loading="eager" class="logo-dark" />
      </div>
      <!-- {
        latestEpisode && (
          <section class="my-64" aria-labelledby="latest-ep-heading">
            <div class="container">
              <div class="mx-auto max-w-3xl">
                <div class="mb-4 flex flex-wrap items-end justify-between gap-4">
                  <div>
                    <p class="text-sm font-medium tracking-wide uppercase" style="color: var(--color-primary)">
                      Featured Episode
                    </p>
                    <Heading level="h4" id="latest-ep-heading" class="mt-1">
                      {latestEpisode.data.title}
                    </Heading>
                    {latestEpisode.data.guestName && <p class="mt-1 text-lg">with {latestEpisode.data.guestName}</p>}
                  </div>
                </div>
                <YouTubePlayer url={latestEpisode.data.youtubeUrl} title={latestEpisode.data.title} />
                {/* <p class="mt-4">{latestEpisode.data.description}</p> */}
                <div class="mt-4">
                  <Link href={`/episodes/${latestEpisode.id}`} isButton type="primary">
                    Show notes & transcript
                  </Link>
                </div>
              </div>
            </div>
          </section>
        )
      } -->
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('listen-btn')
  const menu = document.getElementById('listen-menu')

  btn?.addEventListener('click', (e) => {
    e.stopPropagation()
    const isOpen = btn.getAttribute('aria-expanded') === 'true'
    btn.setAttribute('aria-expanded', String(!isOpen))
    menu?.toggleAttribute('hidden', isOpen)
  })

  document.addEventListener('click', () => {
    btn?.setAttribute('aria-expanded', 'false')
    menu?.setAttribute('hidden', '')
  })

  menu?.addEventListener('click', (e) => e.stopPropagation())
</script>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .listen-dropdown {
    position: relative;
    display: inline-flex;
  }

  .listen-dropdown button {
    display: inline-flex;
    position: relative;
    justify-content: center;
    align-items: center;
    gap: var(--space-2xs);
    cursor: pointer;
    border: 3px solid var(--color-secondary-border);
    border-radius: var(--radius-s);
    background-color: var(--color-secondary-bg);
    padding: var(--space-xs) var(--space-s);
    color: var(--color-secondary-text);
    font-weight: 700;
    font-size: inherit;
    font-family: inherit;
    text-decoration: underline;
    text-decoration-style: solid;
    text-decoration-color: transparent;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: all 0.2s var(--animation-timing);

    &:hover,
    &:focus-visible {
      text-decoration-color: currentColor;
      text-underline-offset: 2px;
    }

    @media (prefers-reduced-motion: no-preference) {
      &:hover,
      &:focus-visible {
        translate: 0 -3px;
      }
    }
  }

  .listen-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    min-width: 180px;
    border: 3px solid var(--color-secondary-border);
    border-radius: var(--radius-s);
    background-color: var(--color-default-bg, var(--color-neutral-100));
    overflow: hidden;
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.12);
  }

  .listen-item {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-xs) var(--space-s);
    color: var(--color-default-text);
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.15s ease;

    &:hover,
    &:focus-visible {
      background-color: var(--color-secondary-bg);
      outline: none;
    }
  }

  .logo-dark {
    display: none;
  }
  :global(.darkmode) .logo-dark {
    display: block;
  }
  :global(.darkmode) .logo-light {
    display: none;
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
