---
import Logo from './Logo.astro'
import { Link } from 'accessible-astro-components'

const currentYear = new Date().getFullYear()

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Episodes', href: '/episodes' },
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
]

const navLinksLeft = navLinks.slice(0, Math.ceil(navLinks.length / 2))
const navLinksRight = navLinks.slice(Math.ceil(navLinks.length / 2))

const legalLinks = [
  { label: 'Accessibility statement', href: '/accessibility-statement' },
  { label: 'Sitemap', href: '/sitemap' },
]
---

<footer>
  <div class="accent-bar"></div>
  <section class="py-10">
    <div class="container">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-[1.4fr_1fr]">
        <div class="flex flex-col items-center md:items-start gap-3 text-center md:text-left">
          <Logo loading="lazy" />
          <p class="footer-tagline">
            A space for South Asian women to share their experiences of living with or supporting
            someone with a rare disease.
          </p>
        </div>
        <div class="flex flex-col justify-center gap-12 md:flex-row md:items-start md:justify-start md:gap-16">
          <div class="flex flex-col items-start gap-2 text-left">
            <p class="footer-heading">Navigate</p>
            <div class="grid grid-cols-2 gap-4">
              <ul class="flex flex-col gap-1">
                {navLinksLeft.map((link) => <li><Link href={link.href}>{link.label}</Link></li>)}
              </ul>
              <ul class="flex flex-col gap-1">
                {navLinksRight.map((link) => <li><Link href={link.href}>{link.label}</Link></li>)}
              </ul>
            </div>
          </div>
          <div class="flex flex-col items-start gap-2 text-left">
            <p class="footer-heading">More</p>
            <ul class="flex flex-col gap-1">
              {legalLinks.map((link) => <li><Link href={link.href}>{link.label}</Link></li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-4">
    <div class="container flex flex-col gap-1 md:flex-row md:items-center md:justify-end md:gap-6">
      <p class="footer-meta">&copy; {currentYear} South Asian Women in Rare. All rights reserved.</p>
      <p class="footer-meta">Made with ❤️ by <Link target="_blank" href="https://mehuldineshjain.github.io">Mehul Jain</Link></p>
    </div>
  </section>
</footer>

<style lang="scss">
  .accent-bar {
    height: 3px;
    background: linear-gradient(
      90deg,
      light-dark(var(--color-primary-400), var(--color-primary-300)),
      light-dark(var(--color-secondary-300), var(--color-secondary-200))
    );
  }

  section {
    border-top: 1px solid var(--border-color-subtle);
  }

  .footer-heading {
    font-size: var(--font-size--2);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: light-dark(var(--color-neutral-600), var(--color-neutral-500));
  }

  .footer-tagline {
    font-size: var(--font-size--1);
    line-height: 1.6;
    color: light-dark(var(--color-neutral-700), var(--color-neutral-400));
  }

  .footer-meta {
    font-size: var(--font-size--2);
    color: light-dark(var(--color-neutral-600), var(--color-neutral-500));
  }
</style>
